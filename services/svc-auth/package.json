{
  "name": "@shexmap/svc-auth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r ../shared/proto ./proto",
    "dev": "NODE_ENV=development tsx watch src/index.ts",
    "start": "node dist/index.js",
