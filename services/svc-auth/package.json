    "@fastify/sensible": "^6.0.0",
    "@shexmap/shared": "*",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
